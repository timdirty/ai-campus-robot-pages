{
  "name": "campus-service-robot-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "start": "tsx server/serialBridge.ts",
    "dev": "concurrently -n web,bridge -c blue,cyan \"npm:dev:web\" \"npm:dev:bridge\"",
    "dev:web": "vite --port=3000 --host=0.0.0.0",
    "dev:bridge": "tsx server/serialBridge.ts",
    "build": "vite build",
    "build:pages": "node ../../scripts/build-github-pages.mjs",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "test:e2e": "node scripts/e2e-stress.mjs",
    "check": "npm run test && npm run lint && npm run build"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@serialport/parser-readline": "^13.0.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "qrcode": "^1.5.4",
    "react-dom": "^19.0.0",
    "serialport": "^13.0.0",
    "tone": "^15.1.22",
    "vite": "^6.2.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/qrcode": "^1.5.5",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
