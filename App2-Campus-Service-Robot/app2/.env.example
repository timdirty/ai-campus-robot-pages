# Google AI Studio / Gemini.
# Fill this on each demo machine. Do not commit real keys.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"
GEMINI_VISION_MODEL="gemini-3.5-flash"

# Optional. Points to App 2's standalone local bridge (npm run dev:bridge).
# The App 2 launcher uses 3203 by default.
BRIDGE_PORT="3204"
VITE_ARDUINO_BRIDGE_URL="http://localhost:3204"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=""
