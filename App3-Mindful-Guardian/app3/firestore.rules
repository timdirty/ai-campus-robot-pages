rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() { return request.auth != null; }
    function isEmailVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // User Profile Rules
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn() && (resource.data.role == 'student' || resource.data.role == 'teacher' || isOwner(userId));
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['lastMood', 'displayName', 'photoURL', 'updatedAt'])
      );

      function isValidUser(data) {
        return data.userId == request.auth.uid
          && data.email is string && data.email.size() <= 200
          && data.role in ['student', 'teacher', 'admin']
          && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
          && data.keys().hasAll(['userId', 'email', 'role']);
      }
    }

    // Alerts Rules (Admin/Teacher view only)
    match /alerts/{alertId} {
      allow read: if isSignedIn(); // Simplified for demo, usually role-based
      allow create: if isSignedIn() && isValidAlert(incoming());
      allow update: if isSignedIn() && isValidAlert(incoming()) && (
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'checklist', 'updatedAt'])
      );

      function isValidAlert(data) {
        return data.studentName is string && data.studentName.size() <= 100
          && data.riskLevel in ['high', 'medium', 'low']
          && data.status in ['new', 'processing', 'resolved']
          && (data.description == null || (data.description is string && data.description.size() <= 1000));
      }
    }

    // Forest Posts Rules
    match /forest_posts/{postId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidPost(incoming());
      allow update: if isSignedIn() && (
        // Only allow updating likes
        incoming().diff(existing()).affectedKeys().hasOnly(['likes'])
      );
      allow delete: if isSignedIn() && existing().authorId == request.auth.uid;

      function isValidPost(data) {
        return data.content is string && data.content.size() <= 500 && data.content.size() > 0
          && data.type in ['thought', 'gratitude', 'support']
          && data.authorId == request.auth.uid
          && data.createdAt == request.time;
      }
    }

    // Interventions Rules
    match /interventions/{id} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn(); // In production, restrict to Admin role
    }

    // Nodes Rules
    match /nodes/{id} {
      allow read: if isSignedIn();
      allow update: if isSignedIn();
    }
  }
}
