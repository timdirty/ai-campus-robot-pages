# Optional. Current demo is local-first and works without Gemini.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-3.5-flash"
GEMINI_VISION_MODEL="gemini-3.5-flash"

# Optional. Points to App 3's standalone local bridge (npm run dev:bridge).
# Leave empty to use the default http://localhost:3203.
VITE_ARDUINO_BRIDGE_URL="http://localhost:3203"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL=""
